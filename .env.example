# Copy this file to ".env" and put your real GitHub Personal Access Token in here.
# The .env file is in .gitignore so it never gets pushed to GitHub.
#
# How to get a token:
#   1. Open https://github.com/settings/tokens
#   2. Click "Generate new token" (classic)
#   3. Note: "GitHub Models for Test Generator", expiration: 90 days
#   4. Under scopes, find and check the "models:read" scope
#   5. Click Generate, then COPY the token immediately
#
# GitHub Models is FREE — no Copilot subscription required.
GITHUB_TOKEN=ghp-paste-your-token-here
